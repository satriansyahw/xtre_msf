@using Licensing.Client.Services
@inject PersonaService PersonaService
@inject NavigationManager Navigation

@implements IDisposable

<div class="persona-switcher d-flex align-items-center">
    <div class="btn-group btn-group-sm" role="group">
        <button type="button" 
                class="btn @(PersonaService.CurrentPersona == Persona.Operator ? "btn-primary shadow-sm" : "btn-outline-primary")" 
                @onclick="() => HandleSwitch(Persona.Operator)">
            <i class="bi bi-person-workspace me-1"></i> Operator
        </button>
        <button type="button" 
                class="btn @(PersonaService.CurrentPersona == Persona.Officer ? "btn-dark shadow-sm" : "btn-outline-dark")" 
                @onclick="() => HandleSwitch(Persona.Officer)">
            <i class="bi bi-shield-check me-1"></i> Officer
        </button>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        PersonaService.OnPersonaChanged += StateHasChanged;
    }

    private async Task HandleSwitch(Persona newPersona)
    {
        if (PersonaService.CurrentPersona == newPersona) return;
        
        await PersonaService.SwitchTo(newPersona);
        
        // Force a hard reload to clear all memory state and data between personas
        var target = newPersona == Persona.Operator ? "/operator" : "/officer";
        Navigation.NavigateTo(target, forceLoad: true);
    }

    public void Dispose()
    {
        PersonaService.OnPersonaChanged -= StateHasChanged;
    }
}
