@using Microsoft.AspNetCore.Components.Forms

<div class="file-upload-zone @(isDragOver ? "drag-over" : "")" 
     @ondragover="HandleDragOver" 
     @ondragleave="HandleDragLeave" 
     @ondrop="HandleDrop">
    
    <div class="upload-content text-center py-4">
        <i class="bi bi-cloud-arrow-up fs-1 text-primary mb-2"></i>
        <p class="mb-1 fw-bold">Drag & drop files here</p>
        <p class="text-muted small mb-3">or click to browse from your device</p>
        
        <InputFile OnChange="OnInputFileChange" class="file-input" multiple id="@Id" />
        <label for="@Id" class="btn btn-outline-primary btn-sm">Select Files</label>
    </div>
</div>

<style>
    .file-upload-zone {
        border: 2px dashed #dee2e6;
        border-radius: 12px;
        transition: all 0.2s ease;
        position: relative;
        background-color: #f8f9fa;
    }

    .file-upload-zone.drag-over {
        border-color: #0d6efd;
        background-color: rgba(13, 110, 253, 0.05);
        transform: scale(1.01);
    }

    .file-input {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        opacity: 0;
        cursor: pointer;
    }

    .upload-content {
        pointer-events: none;
    }
    
    .upload-content .btn {
        pointer-events: auto;
    }
</style>

@code {
    [Parameter] public string Id { get; set; } = "fileInput";
    [Parameter] public EventCallback<InputFileChangeEventArgs> OnChange { get; set; }

    private bool isDragOver = false;

    private void HandleDragOver() => isDragOver = true;
    private void HandleDragLeave() => isDragOver = false;
    private void HandleDrop() => isDragOver = false;

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        await OnChange.InvokeAsync(e);
    }
}
