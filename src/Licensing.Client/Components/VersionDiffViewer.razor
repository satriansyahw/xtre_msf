@using Licensing.Application.DTOs
@using System.Text.Json

<div class="version-diff-viewer mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0">Version Comparison</h6>
        </div>
        <div class="card-body p-0">
            @if (Snapshots == null || Snapshots.Count < 2)
            {
                <div class="p-4 text-center text-muted">
                    Not enough versions to compare. Only Version 1 exists.
                </div>
            }
            else
            {
                <div class="row g-0">
                    <div class="col-md-6 border-end">
                        <div class="bg-light p-2 border-bottom small fw-bold">Version @PreviousVersion.Version (Original)</div>
                        <div class="p-3">
                            @foreach (var kvp in ParseData(PreviousVersion.DataJson))
                            {
                                <div class="mb-1 small">
                                    <span class="text-muted">@kvp.Key:</span> <span>@kvp.Value</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-light p-2 border-bottom small fw-bold">Version @CurrentVersion.Version (Current)</div>
                        <div class="p-3">
                            @foreach (var kvp in ParseData(CurrentVersion.DataJson))
                            {
                                var isChanged = IsFieldChanged(kvp.Key, kvp.Value);
                                <div class='mb-1 small @(isChanged ? "bg-success bg-opacity-10 border-start border-success border-3 ps-2" : "")'>
                                    <span class="text-muted">@kvp.Key:</span> 
                                    <span class='@(isChanged ? "fw-bold" : "")'>@kvp.Value</span>
                                    @if (isChanged)
                                    {
                                        <span class="badge bg-success ms-2" style="font-size: 0.6rem">Changed</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public List<ApplicationSnapshotResponse>? Snapshots { get; set; }
    
    private ApplicationSnapshotResponse CurrentVersion => Snapshots?.OrderByDescending(s => s.Version).FirstOrDefault() ?? new();
    private ApplicationSnapshotResponse PreviousVersion => Snapshots?.OrderByDescending(s => s.Version).Skip(1).FirstOrDefault() ?? new();

    private Dictionary<string, string> ParseData(string json)
    {
        try 
        {
            var data = JsonSerializer.Deserialize<Dictionary<string, object>>(json);
            return data?.ToDictionary(k => k.Key, v => v.Value?.ToString() ?? "") ?? new();
        }
        catch 
        {
            return new();
        }
    }

    private bool IsFieldChanged(string key, string currentValue)
    {
        var prevData = ParseData(PreviousVersion.DataJson);
        return prevData.ContainsKey(key) && prevData[key] != currentValue;
    }
}
