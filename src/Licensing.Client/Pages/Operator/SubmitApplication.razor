@page "/operator/submit"
@using Licensing.Application.DTOs
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">License Application Submission</h3>
        </div>
        <div class="card-body">
            <!-- Progress Stepper -->
            <div class="d-flex justify-content-between mb-4">
                <div class="text-center @(currentStep == 1 ? "fw-bold text-primary" : "text-muted")">
                    <div class="rounded-circle border d-inline-flex align-items-center justify-content-center mb-1" style="width: 30px; height: 30px;">1</div>
                    <small class="d-block">Basic Info</small>
                </div>
                <div class="flex-grow-1 border-bottom mx-2" style="height: 15px;"></div>
                <div class="text-center @(currentStep == 2 ? "fw-bold text-primary" : "text-muted")">
                    <div class="rounded-circle border d-inline-flex align-items-center justify-content-center mb-1" style="width: 30px; height: 30px;">2</div>
                    <small class="d-block">Details</small>
                </div>
                <div class="flex-grow-1 border-bottom mx-2" style="height: 15px;"></div>
                <div class="text-center @(currentStep == 3 ? "fw-bold text-primary" : "text-muted")">
                    <div class="rounded-circle border d-inline-flex align-items-center justify-content-center mb-1" style="width: 30px; height: 30px;">3</div>
                    <small class="d-block">Documents</small>
                </div>
            </div>

            <hr />

            @if (currentStep == 1)
            {
                <div class="step-content">
                    <h5>Step 1: Applicant Information</h5>
                    <div class="mb-3">
                        <label class="form-label">Applicant Full Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control @GetValidationClass(request.ApplicantName)" @bind="request.ApplicantName" placeholder="e.g. John Doe" />
                        @if (string.IsNullOrWhiteSpace(request.ApplicantName) && showValidationErrors)
                        {
                            <div class="invalid-feedback d-block">Applicant name is required.</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Business Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control @GetValidationClass(request.BusinessName)" @bind="request.BusinessName" placeholder="e.g. Acme Corp" />
                        @if (string.IsNullOrWhiteSpace(request.BusinessName) && showValidationErrors)
                        {
                            <div class="invalid-feedback d-block">Business name is required.</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contact Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control @GetValidationClass(request.ContactEmail)" @bind="request.ContactEmail" placeholder="john@example.com" />
                        @if (string.IsNullOrWhiteSpace(request.ContactEmail) && showValidationErrors)
                        {
                            <div class="invalid-feedback d-block">Contact email is required.</div>
                        }
                    </div>
                </div>
            }
            else if (currentStep == 2)
            {
                <div class="step-content">
                    <h5>Step 2: Business Details</h5>
                    <div class="mb-3">
                        <label class="form-label">Proposed Business Address <span class="text-danger">*</span></label>
                        <textarea class="form-control @GetValidationClass(businessAddress)" @bind="businessAddress" rows="3"></textarea>
                        @if (string.IsNullOrWhiteSpace(businessAddress) && showValidationErrors)
                        {
                            <div class="invalid-feedback d-block">Business address is required.</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Number of Employees <span class="text-danger">*</span></label>
                        <input type="number" class="form-control @(employeeCount <= 0 && showValidationErrors ? "is-invalid" : "")" @bind="employeeCount" />
                        @if (employeeCount <= 0 && showValidationErrors)
                        {
                            <div class="invalid-feedback d-block">Please specify number of employees (minimum 1).</div>
                        }
                    </div>
                </div>
            }
            else if (currentStep == 3)
            {
                <div class="step-content">
                    <h5>Step 3: Document Uploads <span class="text-danger">*</span></h5>
                    <p class="text-muted small">Upload your Business Registration and Identity Proof. (Minimum 1 document required)</p>
                    
                    <div class="mb-4">
                        <InputFile OnChange="HandleFileSelected" class="@($"form-control {(showValidationErrors && !uploadedDocuments.Any() ? "is-invalid" : "")}")" multiple />
                        @if (showValidationErrors && !uploadedDocuments.Any())
                        {
                            <div class="invalid-feedback d-block">At least one document is required.</div>
                        }
                    </div>

                    @if (uploadedDocuments.Any())
                    {
                        <ul class="list-group">
                            @foreach (var doc in uploadedDocuments)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="bi bi-file-earmark-check me-2 text-primary"></i>
                                        @doc.FileName
                                    </div>
                                    <span class="badge @GetAIStatusBadgeClass(doc.AIStatus) px-3 py-2">
                                        @if (doc.AIStatus == "Pending")
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        }
                                        @doc.AIStatus
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @errorMessage
                </div>
            }

            <div class="mt-4 d-flex justify-content-between">
                @if (currentStep > 1)
                {
                    <button class="btn btn-outline-secondary" @onclick="PreviousStep">Previous</button>
                }
                else
                {
                    <div></div>
                }

                @if (currentStep < 3)
                {
                    <button class="btn btn-primary" @onclick="NextStep">Next</button>
                }
                else
                {
                    <button class="btn btn-success" @onclick="Submit" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Submit Application
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private int currentStep = 1;
    private SubmitApplicationRequest request = new();
    private bool showValidationErrors = false;
    private bool isSubmitting = false;
    
    // Step 2 specific fields (will be serialized to DataJson)
    private string businessAddress = "";
    private int employeeCount = 1;

    private List<DocumentResponse> uploadedDocuments = new();

    private void NextStep() 
    {
        if (IsStepValid())
        {
            showValidationErrors = false;
            currentStep++;
        }
        else 
        {
            showValidationErrors = true;
        }
    }

    private void PreviousStep() 
    {
        showValidationErrors = false;
        currentStep--;
    }

    private string GetValidationClass(string? value) => 
        showValidationErrors && string.IsNullOrWhiteSpace(value) ? "is-invalid" : "";

    private bool IsStepValid()
    {
        if (currentStep == 1)
            return !string.IsNullOrWhiteSpace(request.ApplicantName) && 
                   !string.IsNullOrWhiteSpace(request.BusinessName) && 
                   !string.IsNullOrWhiteSpace(request.ContactEmail);
        
        if (currentStep == 2)
            return !string.IsNullOrWhiteSpace(businessAddress) && employeeCount > 0;

        if (currentStep == 3)
            return uploadedDocuments.Any();
        
        return true;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        foreach (var file in e.GetMultipleFiles())
        {
            try 
            {
                var content = new MultipartFormDataContent();
                var fileStream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                var fileContent = new StreamContent(fileStream);
                content.Add(fileContent, "file", file.Name);

                var response = await Http.PostAsync("api/uploads", content);
                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<DocumentResponse>();
                    if (result != null)
                    {
                        uploadedDocuments.Add(result);
                        request.DocumentIds.Add(result.Id);
                        showValidationErrors = false; // Reset validation error once a file is added
                        _ = StartPolling(); // Fire and forget polling
                    }
                }
                else 
                {
                    var errorText = await response.Content.ReadAsStringAsync();
                    errorMessage = $"Failed to upload {file.Name}: {(string.IsNullOrEmpty(errorText) ? response.ReasonPhrase : ParseError(errorText))}";
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error uploading {file.Name}: {ex.Message}";
            }
        }
        StateHasChanged();
    }

    private string ParseError(string raw)
    {
        try 
        {
            if (raw.TrimStart().StartsWith("{"))
            {
                using var doc = JsonDocument.Parse(raw);
                if (doc.RootElement.TryGetProperty("errors", out var errors))
                {
                    var msgs = new List<string>();
                    foreach (var prop in errors.EnumerateObject())
                        foreach (var m in prop.Value.EnumerateArray()) msgs.Add(m.GetString() ?? "");
                    return string.Join(" ", msgs);
                }
                if (doc.RootElement.TryGetProperty("title", out var t)) return t.GetString() ?? raw;
            }
            return raw;
        }
        catch { return raw; }
    }

    private bool isPolling = false;
    private async Task StartPolling()
    {
        if (isPolling) return;
        isPolling = true;

        while (uploadedDocuments.Any(d => d.AIStatus == "Pending"))
        {
            await Task.Delay(2000);
            for (int i = 0; i < uploadedDocuments.Count; i++)
            {
                if (uploadedDocuments[i].AIStatus == "Pending")
                {
                    try 
                    {
                        var latest = await Http.GetFromJsonAsync<DocumentResponse>($"api/uploads/{uploadedDocuments[i].Id}");
                        if (latest != null)
                        {
                            uploadedDocuments[i].AIStatus = latest.AIStatus;
                        }
                    }
                    catch { /* Ignore temporary network issues */ }
                }
            }
            StateHasChanged();
        }

        isPolling = false;
    }

    private string GetAIStatusBadgeClass(string status)
    {
        return status switch
        {
            "Verified" => "bg-success",
            "Flagged" => "bg-danger",
            "Pending" => "bg-info text-dark",
            _ => "bg-secondary"
        };
    }

    private string? errorMessage;

    private async Task Submit()
    {
        if (!IsStepValid())
        {
            showValidationErrors = true;
            return;
        }

        isSubmitting = true;
        errorMessage = null;
        
        // Prepare JSON data
        var data = new { BusinessAddress = businessAddress, EmployeeCount = employeeCount };
        request.DataJson = System.Text.Json.JsonSerializer.Serialize(data);

        try 
        {
            var response = await Http.PostAsJsonAsync("api/applications", request);
            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/operator");
            }
            else
            {
                errorMessage = $"Submission failed: {response.ReasonPhrase}. Please check your inputs.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"A network error occurred: {ex.Message}";
        }
        finally 
        {
            isSubmitting = false;
        }
    }
}
