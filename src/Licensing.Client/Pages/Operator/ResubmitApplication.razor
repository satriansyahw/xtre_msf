@page "/operator/resubmit/{Id:guid}"
@using Licensing.Application.DTOs
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Resubmit Application: @app?.ReferenceNumber</h3>
            <span class="badge bg-dark">Version Upgrading</span>
        </div>
        <div class="card-body">
            @if (app == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else
            {
                <div class="alert alert-info border-info mb-4">
                    <h5><i class="bi bi-info-circle me-2"></i>Officer Feedback</h5>
                    <ul class="mb-0">
                        @foreach (var fb in app.Feedbacks)
                        {
                            <li><strong>@fb.FieldName:</strong> @fb.Comment</li>
                        }
                    </ul>
                </div>

                <EditForm Model="request" OnValidSubmit="HandleResubmit">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Applicant Name</label>
                            <InputText class="form-control" @bind-Value="request.ApplicantName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Business Name</label>
                            <InputText class="form-control" @bind-Value="request.BusinessName" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Contact Email</label>
                        <InputText class="form-control" @bind-Value="request.ContactEmail" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Business Address</label>
                            <input type="text" class="form-control" @bind="businessAddress" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Employee Count</label>
                            <input type="number" class="form-control" @bind="employeeCount" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Additional Documents</label>
                        <InputFile class="form-control" OnChange="HandleFileSelected" multiple />
                        @if (uploadedDocuments.Any())
                        {
                            <ul class="list-group mt-2">
                                @foreach (var doc in uploadedDocuments)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        @doc.FileName
                                        <span class="badge bg-success">Ready</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>

                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <button type="button" class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/operator")'>Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Submit Updates
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    private ApplicationResponse? app;
    private SubmitApplicationRequest request = new();
    private bool isSubmitting = false;
    
    private string businessAddress = "";
    private int employeeCount = 0;
    private List<DocumentResponse> uploadedDocuments = new();

    protected override async Task OnInitializedAsync()
    {
        app = await Http.GetFromJsonAsync<ApplicationResponse>($"api/applications/{Id}");
        if (app != null)
        {
            request.ApplicantName = app.ApplicantName;
            request.BusinessName = app.BusinessName;
            request.ContactEmail = app.ContactEmail;
            request.DocumentIds = app.Documents.Select(d => d.Id).ToList();

            try 
            {
                var data = JsonSerializer.Deserialize<Dictionary<string, object>>(app.DataJson);
                if (data != null)
                {
                    businessAddress = data.ContainsKey("BusinessAddress") ? data["BusinessAddress"].ToString() : "";
                    employeeCount = data.ContainsKey("EmployeeCount") ? int.Parse(data["EmployeeCount"].ToString()) : 0;
                }
            }
            catch { }
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/uploads", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<DocumentResponse>();
                if (result != null)
                {
                    uploadedDocuments.Add(result);
                    request.DocumentIds.Add(result.Id);
                }
            }
        }
    }

    private async Task HandleResubmit()
    {
        isSubmitting = true;
        
        var data = new { BusinessAddress = businessAddress, EmployeeCount = employeeCount };
        request.DataJson = JsonSerializer.Serialize(data);

        var response = await Http.PostAsJsonAsync($"api/applications/{Id}/resubmit", request);
        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/operator");
        }
        else
        {
            isSubmitting = false;
        }
    }
}
