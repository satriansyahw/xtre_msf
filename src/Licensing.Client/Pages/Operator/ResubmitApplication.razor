@page "/operator/resubmit/{Id:guid}"
@using Licensing.Application.DTOs
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Resubmit Application: @app?.ReferenceNumber</h3>
            <span class="badge bg-dark">Version Upgrading</span>
        </div>
        <div class="card-body">
            @if (app == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else
            {
                <div class="alert alert-info border-info mb-4">
                    <h5><i class="bi bi-info-circle me-2"></i>Officer Feedback</h5>
                    <ul class="mb-0">
                        @foreach (var fb in app.Feedbacks)
                        {
                            <li><strong>@fb.FieldName:</strong> @fb.Comment</li>
                        }
                    </ul>
                </div>

                <EditForm Model="request" OnValidSubmit="HandleResubmit">
                    <DataAnnotationsValidator />
                    <div class="accordion mb-4" id="resubmitAccordion">
                        <!-- Section 1: Applicant Identity -->
                        <div class="accordion-item shadow-sm border-0 mb-2">
                            <h2 class="accordion-header">
                                <button class="accordion-button @(IsSectionFlagged("Identity") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseIdentity">
                                    <i class="bi bi-person-badge me-2"></i> Applicant Identity
                                    @if (IsSectionFlagged("Identity"))
                                    {
                                        <span class="badge bg-danger ms-2">Flagged</span>
                                    }
                                </button>
                            </h2>
                            <div id="collapseIdentity" class="accordion-collapse collapse @(IsSectionFlagged("Identity") ? "show" : "")" data-bs-parent="#resubmitAccordion">
                                <div class="accordion-body bg-light bg-opacity-10">
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Applicant Name <span class="text-danger">*</span></label>
                                            <InputText class="@GetFieldClass("ApplicantName")" @bind-Value="request.ApplicantName" />
                                            <ValidationMessage For="@(() => request.ApplicantName)" />
                                            @if (IsFieldFlagged("ApplicantName")) { <small class="text-danger d-block mt-1"><strong>Officer Feedback:</strong> @GetFieldFeedback("ApplicantName")</small> }
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Business Name <span class="text-danger">*</span></label>
                                            <InputText class="@GetFieldClass("BusinessName")" @bind-Value="request.BusinessName" />
                                            <ValidationMessage For="@(() => request.BusinessName)" />
                                            @if (IsFieldFlagged("BusinessName")) { <small class="text-danger d-block mt-1"><strong>Officer Feedback:</strong> @GetFieldFeedback("BusinessName")</small> }
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Contact Email <span class="text-danger">*</span></label>
                                        <InputText class="@GetFieldClass("ContactEmail")" @bind-Value="request.ContactEmail" />
                                        <ValidationMessage For="@(() => request.ContactEmail)" />
                                        @if (IsFieldFlagged("ContactEmail")) { <small class="text-danger d-block mt-1"><strong>Officer Feedback:</strong> @GetFieldFeedback("ContactEmail")</small> }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 2: Operational Details -->
                        <div class="accordion-item shadow-sm border-0 mb-2">
                            <h2 class="accordion-header">
                                <button class="accordion-button @(IsSectionFlagged("Operational") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOps">
                                    <i class="bi bi-geo-alt me-2"></i> Operational Details
                                    @if (IsSectionFlagged("Operational"))
                                    {
                                        <span class="badge bg-danger ms-2">Flagged</span>
                                    }
                                </button>
                            </h2>
                            <div id="collapseOps" class="accordion-collapse collapse @(IsSectionFlagged("Operational") ? "show" : "")" data-bs-parent="#resubmitAccordion">
                                <div class="accordion-body bg-light bg-opacity-10">
                                    <div class="row mb-3">
                                        <div class="col-md-8">
                                            <label class="form-label fw-bold">Business Address <span class="text-danger">*</span></label>
                                            <input type="text" class="@GetFieldClass("BusinessAddress")" @bind="businessAddress" />
                                            @if (string.IsNullOrWhiteSpace(businessAddress)) { <div class="text-danger small">Address is required.</div> }
                                            @if (IsFieldFlagged("BusinessAddress")) { <small class="text-danger d-block mt-1"><strong>Officer Feedback:</strong> @GetFieldFeedback("BusinessAddress")</small> }
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-bold">Employee Count <span class="text-danger">*</span></label>
                                            <input type="number" class="@GetFieldClass("EmployeeCount")" @bind="employeeCount" />
                                            @if (employeeCount <= 0) { <div class="text-danger small">Minimum 1 employee.</div> }
                                            @if (IsFieldFlagged("EmployeeCount")) { <small class="text-danger d-block mt-1"><strong>Officer Feedback:</strong> @GetFieldFeedback("EmployeeCount")</small> }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section 3: Documentation -->
                        <div class="accordion-item shadow-sm border-0 mb-2">
                            <h2 class="accordion-header">
                                <button class="accordion-button @(IsFieldFlagged("Documents") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDocs">
                                    <i class="bi bi-file-earmark-arrow-up me-2"></i> Documentation
                                    @if (IsFieldFlagged("Documents"))
                                    {
                                        <span class="badge bg-danger ms-2">Flagged</span>
                                    }
                                </button>
                            </h2>
                            <div id="collapseDocs" class="accordion-collapse collapse @(IsFieldFlagged("Documents") ? "show" : "")" data-bs-parent="#resubmitAccordion">
                                <div class="accordion-body bg-light bg-opacity-10">
                                    <div class="mb-4">
                                        <label class="form-label fw-bold">Additional Documents</label>
                                        <InputFile class="@GetFieldClass("Documents")" OnChange="HandleFileSelected" multiple />
                                        @if (IsFieldFlagged("Documents")) { <small class="text-danger d-block mt-1"><strong>Officer Feedback:</strong> @GetFieldFeedback("Documents")</small> }
                                        
                                        @if (uploadedDocuments.Any())
                                        {
                                            <ul class="list-group mt-2">
                                                @foreach (var doc in uploadedDocuments)
                                                {
                                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                                        @doc.FileName
                                                        <span class="badge bg-success">Ready</span>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <button type="button" class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/operator")'>Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Submit Updates
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    private ApplicationResponse? app;
    private SubmitApplicationRequest request = new();
    private bool isSubmitting = false;
    
    private string businessAddress = "";
    private int employeeCount = 0;
    private List<DocumentResponse> uploadedDocuments = new();

    protected override async Task OnInitializedAsync()
    {
        app = await Http.GetFromJsonAsync<ApplicationResponse>($"api/applications/{Id}");
        if (app != null)
        {
            request.ApplicantName = app.ApplicantName;
            request.BusinessName = app.BusinessName;
            request.ContactEmail = app.ContactEmail;
            request.DocumentIds = app.Documents.Select(d => d.Id).ToList();

            try 
            {
                var data = JsonSerializer.Deserialize<Dictionary<string, object>>(app.DataJson);
                if (data != null)
                {
                    businessAddress = data.ContainsKey("BusinessAddress") ? data["BusinessAddress"]?.ToString() ?? "" : "";
                    employeeCount = data.ContainsKey("EmployeeCount") && data["EmployeeCount"] != null ? int.Parse(data["EmployeeCount"]!.ToString()!) : 0;
                }
            }
            catch { }
        }
    }

    private bool IsFieldFlagged(string fieldName) => 
        app?.Feedbacks?.Any(f => f.FieldName == fieldName && !f.IsResolved) ?? false;

    private string GetFieldFeedback(string fieldName) => 
        app?.Feedbacks?.FirstOrDefault(f => f.FieldName == fieldName && !f.IsResolved)?.Comment ?? "";

    private string GetFieldClass(string fieldName) =>
        $"form-control {(IsFieldFlagged(fieldName) ? "border-danger bg-danger bg-opacity-10" : "")}";

    private bool IsSectionFlagged(string section)
    {
        return section switch
        {
            "Identity" => IsFieldFlagged("ApplicantName") || IsFieldFlagged("BusinessName") || IsFieldFlagged("ContactEmail"),
            "Operational" => IsFieldFlagged("BusinessAddress") || IsFieldFlagged("EmployeeCount"),
            _ => false
        };
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/uploads", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<DocumentResponse>();
                if (result != null)
                {
                    uploadedDocuments.Add(result);
                    request.DocumentIds.Add(result.Id);
                }
            }
        }
    }

    private async Task HandleResubmit()
    {
        isSubmitting = true;
        
        var data = new { BusinessAddress = businessAddress, EmployeeCount = employeeCount };
        request.DataJson = JsonSerializer.Serialize(data);

        var response = await Http.PostAsJsonAsync($"api/applications/{Id}/resubmit", request);
        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/operator");
        }
        else
        {
            isSubmitting = false;
        }
    }
}
