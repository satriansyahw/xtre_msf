@inherits LayoutComponentBase
@using Licensing.Client.Services
@using Licensing.Client.Components
@inject NavigationManager Navigation
@inject PersonaService PersonaService
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center bg-white shadow-sm" style="height: 60px;">
            <div class="d-flex align-items-center">
                <h5 class="mb-0 text-primary fw-bold me-4">RLS Platform</h5>
                <PersonaSwitcher />
            </div>
            <div class="d-flex align-items-center">
                <NotificationBell Persona="@PersonaService.CurrentPersona.ToString()" />
                <div class="ms-3 border-start ps-3 d-none d-md-block">
                    <span class="small text-muted">Welcome, @PersonaService.CurrentPersona</span>
                </div>
            </div>
        </div>

        <article class="content px-4 py-3">
            @if (IsUnauthorized())
            {
                <div class="alert alert-warning mt-4 text-center">
                    <i class="bi bi-exclamation-triangle-fill display-4 d-block mb-3"></i>
                    <h4>Access Restricted</h4>
                    <p>Your current persona (@PersonaService.CurrentPersona) does not have access to this page.</p>
                    <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo(PersonaService.CurrentPersona == Persona.Operator ? "/operator" : "/officer")'>
                        Return to My Dashboard
                    </button>
                </div>
            }
            else
            {
                @Body
            }
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    protected override void OnInitialized()
    {
        PersonaService.OnPersonaChanged += HandlePersonaChanged;
    }

    private void HandlePersonaChanged()
    {
        StateHasChanged();
    }

    private bool IsUnauthorized()
    {
        var path = Navigation.Uri.Replace(Navigation.BaseUri, "").ToLower();
        
        if (path.StartsWith("operator") && PersonaService.CurrentPersona != Persona.Operator) return true;
        if (path.StartsWith("officer") && PersonaService.CurrentPersona != Persona.Officer) return true;
        
        return false;
    }

    public void Dispose()
    {
        PersonaService.OnPersonaChanged -= HandlePersonaChanged;
    }
}
